<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <RollingFile name="RollFile" 
                     fileName="logs/${sys:logFileName}.log" 
                     filePattern="logs/${sys:logFileName}-%d{MM-dd-yyyy}-%i.log">
           
            <Policies>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Root level="info">
            <AppenderRef ref="RollFile"/>
        </Root>
    </Loggers>
</Configuration>
